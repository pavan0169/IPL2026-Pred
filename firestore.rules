rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Matches collection (Detailed match documents)
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Predictions collection (Individual prediction docs)
    match /predictions/{predictionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // AppData collection (Single document store for match states)
    match /appData/matchStates {
      allow read: if true;
      // Only Admin can update match states
      allow write: if request.auth != null;
    }

    // Backup reference
    match /appData/matchResultsReference {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User Predictions collection (Legacy path - optional to keep)
    match /user_predictions/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (userId == request.auth.uid);
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Leagues collection
    match /leagues/{leagueId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
