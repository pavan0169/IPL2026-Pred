rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // AppData collection (Single document store for match states)
    match /appData/matchStates {
      allow read: if true;
      // Only Admin can update match states
      allow write: if request.auth != null;
    }

    // User Predictions collection (One document per user)
    match /user_predictions/{userId} {
      allow read: if true;
      // Users can only write their own document, admins can write to any
      allow write: if request.auth != null && (userId == request.auth.uid);
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Leagues collection
    match /leagues/{leagueId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
